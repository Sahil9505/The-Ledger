# Copy this to .env.local for local dev, or set these in the Vercel dashboard.
# NEVER commit real keys — .env.local is gitignored.

# --- LLM provider (Google Gemini — tried first) ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
# Optional override (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# --- LLM fallback (OpenRouter — used if Gemini fails) ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Web search provider (REQUIRED) ---
# Get a free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# --- Financial Modeling Prep fallback (optional, not configured) ---
# Get a free key at https://financialmodelingprep.com/developer
# FMP_API_KEY=your_fmp_key_here

# --- Server ---
PORT=3000
